<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Interview AI - Create Your Plan</title>
    <link rel="stylesheet" href="/css/base.css" />
    <link rel="stylesheet" href="/css/home.css" />
</head>
<body>

    <div class="top-bar">
        <form method="POST" action="/logout" class="logout-form">
            <button type="submit" class="logout-button">Logout</button>
        </form>
    </div>

    <div id="home-page" class="home-page">

        <header class="page-header">
            <h1>Create Your Custom <span class="highlight">Interview Plan</span></h1>
            <p>Let our AI analyze the job requirements and your unique profile to build a winning strategy.</p>
        </header>

        <% if (error) { %>
            <p class="error-msg error-msg--banner"><%= error %></p>
        <% } %>

        <form class="interview-card" method="POST" action="/" enctype="multipart/form-data">
            <div class="interview-card__body">

                <div class="panel panel--left">
                    <div class="panel__header">
                        <span class="panel__icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2" /><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" /></svg>
                        </span>
                        <h2>Target Job Description</h2>
                        <span class="badge badge--required">Required</span>
                    </div>
                    <textarea
                        id="jobDescription"
                        name="jobDescription"
                        class="panel__textarea"
                        maxlength="5000"
                        required
                        placeholder="Paste the full job description here...&#10;e.g. 'Senior Frontend Engineer at Google requires proficiency in React, TypeScript, and large-scale system design...'"></textarea>
                    <div class="char-counter">Max 5000 characters</div>
                </div>

                <div class="panel-divider"></div>

                <div class="panel panel--right">
                    <div class="panel__header">
                        <span class="panel__icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                        </span>
                        <h2>Your Profile</h2>
                    </div>

                    <div class="upload-section">
                        <label class="section-label" for="resume">
                            Upload Resume
                            <span class="badge badge--best">Best Results</span>
                        </label>
                        <label class="dropzone" for="resume">
                            <span class="dropzone__icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 16 12 12 8 16" /><line x1="12" y1="12" x2="12" y2="21" /><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3" /></svg>
                            </span>
                            <p class="dropzone__title">Click to choose a file</p>
                            <p class="dropzone__subtitle">PDF (Max 3MB)</p>
                            <input type="file" id="resume" name="resume" accept=".pdf" class="dropzone__input" />
                        </label>
                    </div>

                    <div class="or-divider"><span>OR</span></div>

                    <div class="self-description">
                        <label class="section-label" for="selfDescription">Quick Self-Description</label>
                        <textarea
                            id="selfDescription"
                            name="selfDescription"
                            class="panel__textarea panel__textarea--short"
                            placeholder="Briefly describe your experience, key skills, and years of experience if you don't have a resume handy..."></textarea>
                    </div>

                    <div class="info-box">
                        <span class="info-box__icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" stroke="#1a1f27" stroke-width="2" /><line x1="12" y1="16" x2="12.01" y2="16" stroke="#1a1f27" stroke-width="2" /></svg>
                        </span>
                        <p>Either a <strong>Resume</strong> or a <strong>Self Description</strong> is required to generate a personalized plan.</p>
                    </div>
                </div>
            </div>

            <div class="interview-card__footer">
                <span class="footer-info">AI-Powered Strategy Generation &bull; Approx 30s</span>
                <button type="submit" class="generate-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 17l-6.2 4.3 2.4-7.4L2 9.4h7.6z" /></svg>
                    Generate My Interview Strategy
                </button>
            </div>
        </form>

        <% if (reports && reports.length > 0) { %>
        <section class="recent-reports">
            <h2>My Recent Interview Plans</h2>
            <ul class="reports-list">
                <% reports.forEach(function(report) { %>
                    <%
                        var scoreCls = "score--low"
                        if (report.matchScore >= 80) scoreCls = "score--high"
                        else if (report.matchScore >= 60) scoreCls = "score--mid"
                    %>
                    <li class="report-item">
                        <a class="report-item__link" href="/interview/<%= report._id %>">
                            <h3><%= report.title || "Untitled Position" %></h3>
                            <p class="report-meta">Generated on <%= new Date(report.createdAt).toLocaleDateString() %></p>
                            <p class="match-score <%= scoreCls %>">Match Score: <%= report.matchScore %>%</p>
                        </a>
                    </li>
                <% }) %>
            </ul>
        </section>
        <% } %>

        <footer class="page-footer">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Service</a>
            <a href="#">Help Center</a>
        </footer>
    </div>
</body>
</html>
